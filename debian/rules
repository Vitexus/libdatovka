#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --with autoreconf

override_dh_auto_configure:
	dh_auto_configure -- --disable-rpath --disable-doc --enable-openssl-backend

override_dh_auto_test:
	dh_auto_test
	appstreamcli validate --no-net debian/libdatovka8.metainfo.xml

override_dh_install:
	find debian/tmp -name '*.la' -delete
	dh_install
	install -D -m644 debian/libdatovka8.metainfo.xml \
		debian/libdatovka8/usr/share/metainfo/io.github.vitexus.libdatovka.metainfo.xml
	install -D -m644 debian/libdatovka.svg \
		debian/libdatovka8/usr/share/icons/hicolor/scalable/apps/io.github.vitexus.libdatovka.svg

override_dh_installchangelogs:
	dh_installchangelogs NEWS
