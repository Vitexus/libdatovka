prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: @PACKAGE@
Version: @VERSION@
Description: Client library for accessing SOAP services of ISDS 
Requires: libxml-2.0 
Requires.private: libcurl 
Libs: -L${libdir} -lisds
Libs.private: @GPGME_LIBS@ @LIBGCRYPT_LIBS@ @EXPAT_LIBS@
Cflags: -I${includedir}
