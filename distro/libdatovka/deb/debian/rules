#!/usr/bin/make -f
%:
	dh $@ -O--dbgsym-migration='libdatovka-dbg (<< 0.0.0-0~)'

override_dh_auto_configure:
	dh_auto_configure -- --disable-rpath --disable-doc --enable-openssl-backend

override_dh_install:
	dh_install -X.la --fail-missing

override_dh_installchangelogs:
	dh_installchangelogs NEWS
